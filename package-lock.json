{
  "name": "clearpilot-monorepo",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "clearpilot-monorepo",
      "workspaces": [
        "apps/desktop",
        "packages/shared"
      ]
    },
    "apps/desktop": {
      "name": "@clearpilot/desktop",
      "version": "0.0.0"
    },
    "node_modules/@clearpilot/desktop": {
      "resolved": "apps/desktop",
      "link": true
    },
    "node_modules/@clearpilot/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "packages/shared": {
      "name": "@clearpilot/shared",
      "version": "0.0.0"
    }
  }
}
